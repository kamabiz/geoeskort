{
  "name": "geoeskort",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "clean": "rm -rf .next node_modules/.cache",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "git:push": "GIT_SSH_COMMAND=\"ssh -i $(pwd)/.deploy-keys/geoeskort_deploy -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new\" git push origin main",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vercel/blob": "^2.4.1",
    "arctic": "^3.7.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.2",
    "stripe": "^22.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3",
    "typescript": "^5.7.0"
  }
}
