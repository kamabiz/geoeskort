# GitHub PAT for local push (kamabiz account — put in .env.local only, never commit)
# GITHUB_USERNAME=kamabiz
# GITHUB_TOKEN=ghp_...

# Admin credentials (required)
ADMIN_USERNAME=adminuser
ADMIN_PASSWORD=your-secure-password-here
ADMIN_SECRET=generate-a-random-32-character-string

# Community auth (optional; falls back to ADMIN_SECRET)
COMMUNITY_AUTH_SECRET=generate-a-random-32-character-string

# PostgreSQL (Neon) — community + SEO blog admin CMS
DATABASE_URL=postgresql://user:password@localhost:5432/geoeskort?schema=public

# Stripe test keys — premium subscriptions (only when PREMIUM_ENABLED=true)
PREMIUM_ENABLED=false
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Socket.IO server URL (optional; polling fallback when unset)
NEXT_PUBLIC_SOCKET_URL=

# Vercel Blob — optional legacy blog storage (blog now uses DATABASE_URL / Neon)
# Only needed to auto-import old posts from Blob on first deploy; safe to remove after migration
BLOB_READ_WRITE_TOKEN=

# REST API — automated blog publishing (POST /api/posts/publish)
BLOG_PUBLISH_API_KEY=generate-a-random-64-char-hex-string

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Facebook OAuth — https://developers.facebook.com → App → Facebook Login
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
